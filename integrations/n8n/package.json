{
  "name": "n8n-nodes-takuhai",
  "version": "0.0.0",
  "description": "n8n nodes for takuhai — drive ingest, the worker match loop, and any takuhai-shaped crawler.",
  "keywords": ["n8n-community-node-package", "takuhai", "anime"],
  "license": "MIT",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TakuhaiApi.credentials.js",
      "dist/credentials/TakuhaiCrawlerApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Takuhai/Takuhai.node.js",
      "dist/nodes/TakuhaiCrawler/TakuhaiCrawler.node.js",
      "dist/nodes/TakuhaiTrigger/TakuhaiTrigger.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "n8n-workflow": "*",
    "typescript": "^5.7.2"
  }
}
